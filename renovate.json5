{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "github>frantathefranta/renovate-config",
  ],
  "nix": { "enabled": true },
  postUpgradeTasks: {
    commands: ["nix flake lock"],
    fileFilters: ["flake.lock"],
    executionMode: "branch",
  },
  packageRules: [
    {
      matchDepNames: ["nix-community/nh"],
      ignoreUnstable: false,
    },
  ],
  customManagers: [
    {
      customType: "regex",
      description: "Update flake inputs pinned with ?tag=",
      fileMatch: ["^flake\\.nix$"],
      matchStrings: [
        '"github:(?<depName>[^?"]+)\\?tag=(?<currentValue>[^"]+)"',
      ],
      datasourceTemplate: "github-tags",
    },
  ],
}
