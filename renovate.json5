{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'github>frantathefranta/renovate-config',
  ],
  nix: {
    enabled: true,
  },
  packageRules: [
    {
      matchDepNames: [
        'nix-community/nh',
      ],
      ignoreUnstable: false,
    },
    {
      matchFileNames: ['flake.nix'],
      postUpgradeTasks: {
        commands: [
          '/run/current-system/sw/bin/nix flake lock --accept-flake-config',
        ],
        fileFilters: [
          'flake.lock',
        ],
        executionMode: 'branch',
      },
    },
    {
      matchDatasources: ['terraform-provider'],
      registryUrls: ['https://registry.opentofu.org'],
    },
    {
      matchDepNames: ['hashicorp/terraform'],
      enabled: false,
    },
  ],
  customManagers: [
    {
      customType: 'regex',
      description: 'Update flake inputs pinned with ?ref=refs/tags/',
      managerFilePatterns: [
        '/^flake\\.nix$/',
      ],
      matchStrings: [
        '"github:(?<depName>[^?"]+)\\?ref=refs/tags/(?<currentValue>[^"]+)"',
      ],
      datasourceTemplate: 'github-tags',
    },
  ],
  gitAuthor: 'Lord of Lighting [bot] <lol@franta.us>',
}
